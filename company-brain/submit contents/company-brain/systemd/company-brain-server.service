[Unit]
Description=Company Brain ingest API
After=network.target

[Service]
Type=simple
User=chr
WorkingDirectory=/srv/company-brain
EnvironmentFile=/srv/company-brain/.env
Environment=PYTHONUNBUFFERED=1
ExecStart=/srv/company-brain/.venv/bin/python server.py
Restart=on-failure
RestartSec=3
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
